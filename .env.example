# Copier ce fichier en .env et remplir les valeurs
# Ne jamais commiter .env dans git

# Credentials Spotify (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# URL de redirection OAuth — doit correspondre exactement à celle configurée dans le dashboard Spotify
SPOTIFY_REDIRECT_URI=http://localhost:8000/auth/callback

# Chemin du fichier de tokens (optionnel, défaut : .tokens.json)
# SPOTIFY_TOKENS_FILE=.tokens.json
